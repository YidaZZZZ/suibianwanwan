# Pyright配置文件
# 解决Flask框架的类型检查问题

[tool.pyright]
# 忽略特定的严格检查
strict = []

# 忽略reportAny警告（Flask框架返回类型）
typeCheckingMode = "standard"

# Python版本
pythonVersion = "3.9"

# 忽略特定错误
reportUnknownVariableType = "warning"
reportUnknownMemberType = "warning"
reportUnknownArgumentType = "warning"
reportAny = "none"
reportMissingTypeArgument = "none"
