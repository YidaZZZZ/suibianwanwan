{
  "paths": {
    "symbolic": {
      "name": "符号层面路径",
      "description": "神经网络输出 → 证明语言（Coq/Lean）→ 类型检查器 → 真值",
      "components": {
        "neuralOutput": {
          "name": "神经输出层",
          "type": "pattern_recognition",
          "role": "直觉猜测和模式匹配",
          "output": "候选结论"
        },
        "proofTranslation": {
          "name": "证明转换层",
          "type": "translation",
          "supportedLanguages": [
            "Coq",
            "Lean",
            "Agda",
            "Isabelle/HOL"
          ],
          "role": "将直觉输出转换为形式化证明脚本"
        },
        "typeChecker": {
          "name": "类型检查器",
          "type": "verification",
          "role": "验证证明的合法性",
          "strictness": "formal",
          "output": "验证结果（Valid/Invalid）"
        },
        "truthEvaluator": {
          "name": "真值评估器",
          "type": "truth_value",
          "role": "基于类型检查结果输出最终真值",
          "output": "True/False/Unknown"
        }
      },
      "workflow": [
        {
          "step": 1,
          "name": "模式识别",
          "module": "neuralOutput",
          "description": "神经网络基于训练数据生成直觉性结论"
        },
        {
          "step": 2,
          "name": "形式化转换",
          "module": "proofTranslation",
          "description": "将直觉结论映射到证明语言的表达式"
        },
        {
          "step": 3,
          "name": "类型检查",
          "module": "typeChecker",
          "description": "验证证明脚本是否符合类型系统规则"
        },
        {
          "step": 4,
          "name": "真值评估",
          "module": "truthEvaluator",
          "description": "基于验证结果确定逻辑真值"
        }
      ]
    },
    "neuroSymbolic": {
      "name": "神经符号融合路径",
      "description": "神经网络模式识别 + 符号系统形式验证 + 元认知反馈",
      "architecture": "hybrid",
      "components": {
        "neuralModule": {
          "name": "神经模块",
          "type": "neural_network",
          "functions": [
            "pattern_recognition",
            "intuition_generation",
            "semantic_understanding"
          ],
          "output": "直觉预测和置信度"
        },
        "symbolicModule": {
          "name": "符号模块",
          "type": "proof_assistant",
          "supportedSystems": [
            "Coq",
            "Lean",
            "Isabelle",
            "HOL"
          ],
          "functions": [
            "proof_generation",
            "formal_verification",
            "logical_deduction"
          ],
          "output": "形式化证明"
        },
        "metaCognitive": {
          "name": "元认知模块",
          "type": "comparison_monitor",
          "functions": [
            "compare_outputs",
            "detect_discrepancies",
            "adjust_confidence"
          ],
          "output": "一致性评估和调整信号"
        },
        "feedbackLoop": {
          "name": "反馈循环",
          "type": "reinforcement",
          "direction": "bidirectional",
          "functions": [
            "neural_adjustment",
            "symbolic_refinement"
          ]
        }
      },
      "integrationStrategy": {
        "parallel": {
          "description": "神经和符号模块并行运行",
          "trigger": "all_reasoning_tasks"
        },
        "sequential": {
          "description": "神经输出→符号验证→反馈",
          "trigger": "critical_reasoning"
        },
        "iterative": {
          "description": "多次迭代直到收敛",
          "trigger": "complex_proofs",
          "maxIterations": 10,
          "convergenceThreshold": 0.95
        }
      },
      "decisionPolicy": {
        "trustNeural": {
          "threshold": 0.9,
          "condition": "符号验证通过且置信度高"
        },
        "trustSymbolic": {
          "threshold": 0.7,
          "condition": "神经置信度低但形式化证明完整"
        },
        "requestHuman": {
          "threshold": 0.5,
          "condition": "两者冲突或置信度都低"
        }
      }
    },
    "learnedDependentTypes": {
      "name": "学习型依赖类型系统",
      "description": "神经网络学习依赖类型系统，将直觉和逻辑在类型层面统一",
      "theoreticalFoundation": "Curry-Howard Correspondence",
      "components": {
        "typeLearner": {
          "name": "类型学习器",
          "type": "neural_type_system",
          "functions": [
            "learn_type_patterns",
            "infer_dependent_types",
            "generalize_type_constructors"
          ],
          "capabilities": {
            "dependentTypes": true,
            "typeInference": true,
            "typeSynthesis": true
          }
        },
        "proofGenerator": {
          "name": "证明生成器",
          "type": "neural_prover",
          "input": "问题陈述 + 类型提示",
          "output": "候选证明项",
          "mode": "constructive"
        },
        "typeSystem": {
          "name": "类型系统",
          "base": "Dependent Type Theory",
          "extensions": [
            "NeuralTypeAnnotations",
            "ConfidenceTypes",
            "LearningTypes"
          ],
          "rules": {
            "formation": "自动类型构造",
            "introduction": "智能引入规则",
            "elimination": "语义消去规则",
            "computation": "优化计算规则"
          }
        },
        "verificationKernel": {
          "name": "验证内核",
          "type": "type_checker",
          "properties": {
            "soundness": "guaranteed",
            "completeness": "best_effort",
            "decidability": "for_learned_types"
          }
        }
      },
      "learningMechanism": {
        "typePatternExtraction": {
          "description": "从证明示例中提取类型模式",
          "method": "neural_inductive_programming"
        },
        "dependentTypeInference": {
          "description": "推断输入与输出之间的依赖关系",
          "method": "gradient_based_type_inference"
        },
        "proofSynthesis": {
          "description": "基于类型提示合成证明",
          "method": "search_based_proof_generation"
        }
      },
      "exampleSchema": {
        "logicalReasoning": {
          "type": "LogicalReasoning NeuralNetwork",
          "constructors": [
            {
              "name": "PatternRecognition",
              "fields": [
                {
                  "name": "pattern",
                  "type": "NeuralInput"
                },
                {
                  "name": "prediction",
                  "type": "BrainPrediction"
                },
                {
                  "name": "confidence",
                  "type": "Confidence"
                }
              ]
            },
            {
              "name": "FormalVerification",
              "fields": [
                {
                  "name": "proof",
                  "type": "ProofScript"
                },
                {
                  "name": "verification",
                  "type": "TypeCheck proof Success"
                }
              ]
            }
          ]
        }
      }
    }
  },
  "globalSettings": {
    "activePath": "all",
    "pathPriority": {
      "symbolic": 1,
      "neuroSymbolic": 2,
      "learnedDependentTypes": 3
    },
    "fallbackBehavior": {
      "condition": "所有路径失败",
      "action": "标记为未知，请求人类干预"
    },
    "confidenceAggregation": {
      "method": "weighted_average",
      "weights": {
        "symbolic": 0.3,
        "neuroSymbolic": 0.4,
        "learnedDependentTypes": 0.3
      }
    },
    "logging": {
      "enabled": true,
      "level": "detailed",
      "track": [
        "path_selection",
        "intermediate_outputs",
        "verification_results",
        "decision_reasons"
      ]
    }
  },
  "integration": {
    "withThinkingEngine": {
      "enabled": true,
      "mapping": {
        "analytical": "symbolic",
        "reflective": "neuroSymbolic",
        "creative": "learnedDependentTypes"
      }
    },
    "withMemorySystem": {
      "enabled": true,
      "learningFromProofs": {
        "type": "episodic",
        "consolidateAfter": "successful_verification"
      },
      "typeKnowledge": {
        "type": "semantic",
        "persistence": true
      }
    }
  }
}
